### 11.2 ResponseNormalizer 实现

```java
public class ResponseNormalizer {

    private static final ObjectMapper MAPPER = new ObjectMapper();
    private final NormalizeConfig config;
    private final List<Pattern> compiledPatterns;

    public ResponseNormalizer(NormalizeConfig config) {
        this.config = config;
        this.compiledPatterns = config.getIgnorePatterns().stream()
            .map(Pattern::compile)
            .collect(Collectors.toList());
    }

    public String normalize(String responseBody) {
        if (responseBody == null || responseBody.isBlank()) return responseBody;
        try {
            JsonNode root = MAPPER.readTree(responseBody);
            removeFields(root);
            return MAPPER.writeValueAsString(root);
        } catch (JsonProcessingException e) {
            throw new NormalizationException("Failed to normalize response body", e);
        }
    }

    private void removeFields(JsonNode node) {
        if (node.isObject()) {
            ObjectNode obj = (ObjectNode) node;
            List<String> toRemove = new ArrayList<>();
            node.fieldNames().forEachRemaining(fieldName -> {
                if (shouldIgnore(fieldName)) {
                    toRemove.add(fieldName);
                } else {
                    removeFields(node.get(fieldName));
                }
            });
            obj.remove(toRemove);
        } else if (node.isArray()) {
            node.forEach(this::removeFields);
        }
    }

    private boolean shouldIgnore(String fieldName) {
        if (config.getIgnoreFields().contains(fieldName)) return true;
        return compiledPatterns.stream()
            .anyMatch(p -> p.matcher(fieldName).matches());
    }
}
```

