### 18.2 实时日志推送（SSE）

```java
@RestController
@RequestMapping("/api/executions")
public class ExecutionController {

    @PostMapping
    public ResponseEntity<ExecutionStartResponse> startExecution(
            @RequestBody ExecutionRequest request) {
        String executionId = executionService.submit(request);
        return ResponseEntity.ok(new ExecutionStartResponse(executionId));
    }

    @GetMapping(value = "/{executionId}/stream",
                produces = MediaType.TEXT_EVENT_STREAM_VALUE)
    public SseEmitter streamExecution(@PathVariable String executionId) {
        SseEmitter emitter = new SseEmitter(300_000L);

        eventBus.subscribe(executionId, event -> {
            try {
                emitter.send(SseEmitter.event()
                    .name(event.getType())
                    .id(event.getEventId())
                    .data(JsonUtil.toJson(event)));
                if ("suite_complete".equals(event.getType())) {
                    emitter.complete();
                }
            } catch (IOException e) {
                emitter.completeWithError(e);
            }
        });

        emitter.onTimeout(() -> eventBus.unsubscribe(executionId));
        emitter.onCompletion(() -> eventBus.unsubscribe(executionId));
        return emitter;
    }

    @GetMapping("/{executionId}")
    public ResponseEntity<ExecutionStatus> getStatus(@PathVariable String executionId) {
        return ResponseEntity.ok(executionService.getStatus(executionId));
    }

    @GetMapping("/{executionId}/report")
    public ResponseEntity<SuiteResult> getReport(@PathVariable String executionId) {
        return ResponseEntity.ok(executionService.getResult(executionId));
    }
}
```

