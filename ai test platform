## 12. 动态 JUnit 执行

```java
@ExtendWith(AllureJunit5.class)
public class DynamicSuiteRunner {

    @TestFactory
    Stream<DynamicTest> runSuite(
            @ConvertWith(SuiteArgConverter.class) TestSuite suite) {

        ExecutionContext context = ExecutionContextFactory.create(suite);
        List<ApiCase> ordered = DependencyResolver.topologicalSort(suite.getCases());

        return ordered.stream().map(apiCase ->
            DynamicTest.dynamicTest(
                "[" + apiCase.getPriority() + "] " + apiCase.getName(),
                () -> {
                    if (context.evaluateSkipCondition(apiCase.getSkipIf())) {
                        assumeTrue(false, "Skipped by skipIf: " + apiCase.getSkipIf());
                        return;
                    }

                    if (!context.isDependencySatisfied(apiCase.getDependsOn())) {
                        assumeTrue(false, "Dependency not satisfied: " + apiCase.getDependsOn());
                        return;
                    }

                    CaseResult result = CaseExecutor.execute(apiCase, context);
                    context.recordResult(apiCase.getId(), result);

                    if (!result.isPassed() && apiCase.getOnFailure() == FailureAction.ABORT) {
                        throw new SuiteAbortException(
                            "Case failed with ABORT policy: " + apiCase.getName());
                    }

                    assertTrue(result.isPassed(), result.getFailureReason());
                }
            )
        );
    }
}
```

