### 7.3 ExecutionContext

```java
public class ExecutionContext {

    private final String executionId;
    private final String suiteId;
    private final String envName;
    private final EnvConfig envConfig;
    private final Instant startTime;
    private final ConcurrentHashMap<String, String> variables;
    private final ConcurrentHashMap<String, CaseResult> caseResults;

    public void setVariable(String key, String value) {
        variables.put(key, value);
    }

    public String resolve(String template) {
        if (template == null) return null;
        return VariableResolver.resolve(template, variables);
    }

    public boolean isDependencySatisfied(String dependsOnCaseId) {
        if (dependsOnCaseId == null) return true;
        CaseResult result = caseResults.get(dependsOnCaseId);
        return result != null && result.isPassed();
    }

    public String getBaseUrl(String version) {
        return envConfig.getBaseUrl(version);
    }

    public boolean evaluateSkipCondition(String skipIfExpr) {
        if (skipIfExpr == null || skipIfExpr.isBlank()) return false;
        return ExpressionEvaluator.evaluate(resolve(skipIfExpr));
    }

    public void recordResult(String caseId, CaseResult result) {
        caseResults.put(caseId, result);
    }
}
```

