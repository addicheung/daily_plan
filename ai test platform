## 6. DSL 设计

### 6.1 环境配置文件 env/uat.yaml

```yaml
env: uat
baseUrl:
  v1: https://api-v1.example.com
  v2: https://api-v2.example.com

timeout:
  connect: 5000
  read: 10000
  write: 10000

retry:
  maxAttempts: 3
  intervalMs: 1000
  retryOnStatus: [502, 503, 504]

auth:
  type: oauth2
  tokenUrl: ${AUTH_TOKEN_URL}
  clientId: ${AUTH_CLIENT_ID}
  clientSecret: ${AUTH_CLIENT_SECRET}
```

### 6.2 Suite 文件 suites/payment.yaml

```yaml
suite: payment
version: "1.0"
description: "支付模块核心流程验证"

variables:
  username: demo
  currency: CNY
  password: ${TEST_PASSWORD}

compare:
  enabled: true
  mode: semantic
  customFields:
    - data.balance
    - data.currency
  timingThresholdMs: 500
  failOnTimingExceed: false

ignoreFields:
  - traceId
  - requestId
  - timestamp
  - nonce
  - signature

ignorePatterns:
  - ".*Time$"
  - ".*Id$"
  - ".*Token$"

globalAssert:
  headers:
    Content-Type: application/json

hooks:
  beforeSuite: setupTestData
  afterSuite: cleanupTestData

tests:

  - id: tc_login
    name: "用户登录获取 Token"
    tags: [smoke, regression]
    priority: P0

    request:
      method: POST
      path: /api/login
      headers:
        Content-Type: application/json
        X-Request-Source: api-test
      body:
        username: ${username}
        password: ${password}

    assert:
      status: 200
      json:
        - path: "$.code"
          expect: 0
          op: eq
        - path: "$.data.token"
          op: exists
        - path: "$.message"
          expect: "success"
          op: eq
      schema: schemas/login_response.json

    extract:
      - var: token
        from: json
        path: "$.data.token"
      - var: userId
        from: json
        path: "$.data.userId"

    retry:
      maxAttempts: 2
      intervalMs: 500

    timeout:
      read: 5000

  - id: tc_query_balance
    name: "查询账户余额"
    tags: [regression]
    priority: P1
    dependsOn: tc_login
    skipIf: "${token} == ''"

    request:
      method: GET
      path: /api/balance
      params:
        currency: ${currency}
      headers:
        Authorization: "Bearer ${token}"
        X-User-Id: ${userId}

    assert:
      status: 200
      json:
        - path: "$.code"
          expect: 0
          op: eq
        - path: "$.data.balance"
          op: gte
          expect: 0
        - path: "$.data.currency"
          expect: ${currency}
          op: eq
      schema: schemas/balance_response.json

    extract:
      - var: currentBalance
        from: json
        path: "$.data.balance"

  - id: tc_transfer
    name: "发起转账"
    tags: [regression]
    priority: P1
    dependsOn: tc_query_balance

    request:
      method: POST
      path: /api/transfer
      headers:
        Authorization: "Bearer ${token}"
        Content-Type: application/json
      body:
        fromUserId: ${userId}
        amount: 100
        currency: ${currency}
        remark: "API Test Transfer"

    assert:
      status: 200
      json:
        - path: "$.code"
          expect: 0
          op: eq
        - path: "$.data.transactionId"
          op: exists

    onFailure: continue
```

