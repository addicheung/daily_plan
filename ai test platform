### 13.2 日志脱敏

```java
public class SensitiveDataMasker {

    private static final Set<String> SENSITIVE_HEADER_KEYS = Set.of(
        "authorization", "x-api-key", "x-auth-token"
    );

    private static final Set<String> SENSITIVE_BODY_KEYS = Set.of(
        "password", "secret", "token", "apiKey",
        "clientSecret", "privateKey", "accessToken"
    );

    private static final String MASK = "****";

    public static HttpResponse mask(HttpResponse response) {
        return HttpResponse.builder()
            .statusCode(response.getStatusCode())
            .headers(maskHeaders(response.getHeaders()))
            .bodyRaw(maskBody(response.getBodyRaw()))
            .durationMs(response.getDurationMs())
            .version(response.getVersion())
            .build();
    }

    private static Map<String, String> maskHeaders(Map<String, String> headers) {
        Map<String, String> masked = new LinkedHashMap<>(headers);
        SENSITIVE_HEADER_KEYS.forEach(key ->
            masked.computeIfPresent(key, (k, v) -> MASK));
        return masked;
    }
}
```

